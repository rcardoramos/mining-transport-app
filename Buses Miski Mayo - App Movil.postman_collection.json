  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Test comun: valida el wrapper corporativo { Success, Message, Data }.",
          "var json;",
          "try { json = pm.response.json(); } catch (e) { json = null; }",
          "pm.test('Respuesta con wrapper .NET (Success/Message)', function () {",
          "    pm.expect(json, 'cuerpo JSON').to.be.an('object');",
          "    pm.expect(json).to.have.property('Success');",
          "    pm.expect(json).to.have.property('Message');",
          "});"
        ]
      }
    }
